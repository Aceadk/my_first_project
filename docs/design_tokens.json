{
  "$schema": "https://json.schemastore.org/design-tokens.json",
  "color": {
    "brand": {
      "primary": { "$type": "color", "$value": "#FF4D6D" },
      "primaryDark": { "$type": "color", "$value": "#E03B5F" },
      "secondary": { "$type": "color", "$value": "#7B6CFF" },
      "accent": { "$type": "color", "$value": "#4DD6A7" }
    },
    "ink": {
      "900": { "$type": "color", "$value": "#0B0B10" },
      "800": { "$type": "color", "$value": "#14141B" },
      "700": { "$type": "color", "$value": "#1E1E28" },
      "600": { "$type": "color", "$value": "#2A2A36" },
      "500": { "$type": "color", "$value": "#3A3A4A" },
      "400": { "$type": "color", "$value": "#4A4A5E" },
      "300": { "$type": "color", "$value": "#6D6D86" },
      "200": { "$type": "color", "$value": "#A0A0B8" },
      "100": { "$type": "color", "$value": "#D6D6E6" },
      "50": { "$type": "color", "$value": "#F5F5FA" }
    },
    "surface": {
      "backgroundLight": { "$type": "color", "$value": "#F8F7FB" },
      "surfaceLight": { "$type": "color", "$value": "#FFFFFF" },
      "surfaceElevatedLight": { "$type": "color", "$value": "#FDFDFF" },
      "backgroundDark": { "$type": "color", "$value": "#0D0E12" },
      "surfaceDark": { "$type": "color", "$value": "#14141B" },
      "surfaceElevatedDark": { "$type": "color", "$value": "#1E1E28" }
    },
    "text": {
      "primaryLight": { "$type": "color", "$value": "#0B0B10" },
      "mutedLight": { "$type": "color", "$value": "#6D6D86" },
      "primaryDark": { "$type": "color", "$value": "#F5F5FA" },
      "mutedDark": { "$type": "color", "$value": "#A0A0B8" }
    },
    "border": {
      "light": { "$type": "color", "$value": "#E6E4F2" },
      "dark": { "$type": "color", "$value": "#2A2A36" }
    },
    "input": {
      "light": { "$type": "color", "$value": "#F3F2F7" },
      "dark": { "$type": "color", "$value": "#1B1C24" }
    },
    "status": {
      "success": { "$type": "color", "$value": "#43C59E" },
      "warning": { "$type": "color", "$value": "#F7B955" },
      "error": { "$type": "color", "$value": "#FF5A6E" },
      "info": { "$type": "color", "$value": "#5BB3FF" }
    },
    "overlay": {
      "light": { "$type": "color", "$value": "#14000000" },
      "medium": { "$type": "color", "$value": "#33000000" },
      "dark": { "$type": "color", "$value": "#66000000" }
    },
    "divider": {
      "light": { "$type": "color", "$value": "#E6E4F2" },
      "dark": { "$type": "color", "$value": "#2A2A36" }
    },
    "glass": {
      "surfaceLight": { "$type": "color", "$value": "#B8FFFFFF" },
      "surfaceMediumLight": { "$type": "color", "$value": "#CCFFFFFF" },
      "surfaceHeavyLight": { "$type": "color", "$value": "#E6FFFFFF" },
      "surfaceDark": { "$type": "color", "$value": "#B314141B" },
      "surfaceMediumDark": { "$type": "color", "$value": "#CC14141B" },
      "surfaceHeavyDark": { "$type": "color", "$value": "#E61E1E28" },
      "borderLight": { "$type": "color", "$value": "#40FFFFFF" },
      "borderDark": { "$type": "color", "$value": "#26FFFFFF" },
      "frostLight": { "$type": "color", "$value": "#D9FFFFFF" },
      "frostDark": { "$type": "color", "$value": "#B3000000" }
    }
  },
  "font": {
    "family": {
      "body": { "$type": "fontFamily", "$value": "Plus Jakarta Sans" },
      "display": { "$type": "fontFamily", "$value": "Playfair Display" }
    }
  },
  "typography": {
    "displayLarge": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.display}",
        "fontSize": 34,
        "fontWeight": 600,
        "lineHeight": 1.12,
        "letterSpacing": -0.4
      }
    },
    "displayMedium": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.display}",
        "fontSize": 28,
        "fontWeight": 600,
        "lineHeight": 1.21,
        "letterSpacing": -0.3
      }
    },
    "displaySmall": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.display}",
        "fontSize": 22,
        "fontWeight": 600,
        "lineHeight": 1.27,
        "letterSpacing": -0.2
      }
    },
    "titleLarge": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.body}",
        "fontSize": 18,
        "fontWeight": 600,
        "lineHeight": 1.33
      }
    },
    "titleMedium": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.body}",
        "fontSize": 16,
        "fontWeight": 600,
        "lineHeight": 1.38
      }
    },
    "bodyLarge": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.body}",
        "fontSize": 16,
        "fontWeight": 400,
        "lineHeight": 1.5
      }
    },
    "bodyMedium": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.body}",
        "fontSize": 14,
        "fontWeight": 400,
        "lineHeight": 1.55
      }
    },
    "bodySmall": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.body}",
        "fontSize": 12,
        "fontWeight": 400,
        "lineHeight": 1.5
      }
    },
    "labelLarge": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.body}",
        "fontSize": 14,
        "fontWeight": 600,
        "lineHeight": 1.3
      }
    },
    "labelMedium": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.body}",
        "fontSize": 12,
        "fontWeight": 600,
        "lineHeight": 1.3
      }
    },
    "labelSmall": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.body}",
        "fontSize": 10,
        "fontWeight": 600,
        "lineHeight": 1.3
      }
    }
  },
  "spacing": {
    "xs": { "$type": "dimension", "$value": 4 },
    "sm": { "$type": "dimension", "$value": 8 },
    "md": { "$type": "dimension", "$value": 12 },
    "lg": { "$type": "dimension", "$value": 16 },
    "xl": { "$type": "dimension", "$value": 20 },
    "xxl": { "$type": "dimension", "$value": 24 },
    "xxxl": { "$type": "dimension", "$value": 32 },
    "huge": { "$type": "dimension", "$value": 40 }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": 10 },
    "md": { "$type": "dimension", "$value": 14 },
    "lg": { "$type": "dimension", "$value": 20 },
    "xl": { "$type": "dimension", "$value": 24 },
    "xxl": { "$type": "dimension", "$value": 32 },
    "card": { "$type": "dimension", "$value": 20 },
    "cardSm": { "$type": "dimension", "$value": 16 },
    "input": { "$type": "dimension", "$value": 14 },
    "chip": { "$type": "dimension", "$value": 12 },
    "round": { "$type": "dimension", "$value": 1000 }
  },
  "elevation": {
    "low": { "$type": "dimension", "$value": 0 },
    "mid": { "$type": "dimension", "$value": 2 },
    "high": { "$type": "dimension", "$value": 6 }
  },
  "blur": {
    "subtle": { "$type": "dimension", "$value": 2 },
    "light": { "$type": "dimension", "$value": 4 },
    "medium": { "$type": "dimension", "$value": 6 },
    "heavy": { "$type": "dimension", "$value": 10 },
    "extreme": { "$type": "dimension", "$value": 16 }
  },
  "gradient": {
    "primaryVertical": {
      "$type": "gradient",
      "$value": {
        "type": "linear",
        "rotation": 90,
        "stops": [
          { "color": "#FF4D6D", "position": 0 },
          { "color": "#7B6CFF", "position": 1 }
        ]
      }
    },
    "primaryHorizontal": {
      "$type": "gradient",
      "$value": {
        "type": "linear",
        "rotation": 0,
        "stops": [
          { "color": "#FF4D6D", "position": 0 },
          { "color": "#7B6CFF", "position": 1 }
        ]
      }
    },
    "primaryDiagonal": {
      "$type": "gradient",
      "$value": {
        "type": "linear",
        "rotation": 45,
        "stops": [
          { "color": "#FF4D6D", "position": 0 },
          { "color": "#7B6CFF", "position": 1 }
        ]
      }
    },
    "roseSoft": {
      "$type": "gradient",
      "$value": {
        "type": "linear",
        "rotation": 45,
        "stops": [
          { "color": "#FF6F86", "position": 0 },
          { "color": "#FFA3B1", "position": 1 }
        ]
      }
    }
  }
}
