rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isImage() {
      // Whitelist safe image types — block SVG (can contain scripts)
      return request.resource.contentType == 'image/jpeg'
          || request.resource.contentType == 'image/png'
          || request.resource.contentType == 'image/webp'
          || request.resource.contentType == 'image/heic'
          || request.resource.contentType == 'image/heif';
    }

    function isVideo() {
      return request.resource.contentType == 'video/mp4'
          || request.resource.contentType == 'video/quicktime'
          || request.resource.contentType == 'video/webm';
    }

    function isValidMediaType() {
      return isImage() || isVideo();
    }

    function isUnderSizeLimit() {
      // 50MB limit for videos, 10MB for images
      return (isVideo() && request.resource.size < 50 * 1024 * 1024) ||
             (isImage() && request.resource.size < 10 * 1024 * 1024);
    }

    // User profile media (photos, videos) - generic path
    match /users/{uid}/media/{fileName} {
      // Anyone signed in can read user media (for discovery, profiles)
      allow read: if isSignedIn();

      // Only owner can upload/update/delete their own media
      allow write: if isOwner(uid)
                   && isValidMediaType()
                   && isUnderSizeLimit();
    }

    // User profile photos - actual path used by ProfileMediaService
    match /users/{uid}/photos/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid)
                   && isImage()
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // User profile videos - actual path used by ProfileMediaService
    match /users/{uid}/videos/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid)
                   && isVideo()
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // User story media (24h stories)
    match /users/{uid}/stories/{storyId} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid)
                   && isValidMediaType()
                   && isUnderSizeLimit();
    }

    // Chat media (images, videos in messages) - legacy path
    match /chats/{matchId}/{messageId}/{fileName} {
      // Direct reads restricted to authenticated users.
      // For proper per-match access control, use getChatMediaSignedUrl
      // Cloud Function which verifies match participation (CR-AUD-030).
      allow read: if isSignedIn();

      // Only signed-in users can upload chat media with valid types
      allow write: if isSignedIn()
                   && isValidMediaType()
                   && isUnderSizeLimit();
    }

    // Chat media - current path used by Firebase repository
    // Path: chat_media/{matchId}/{userId}/{fileName}
    match /chat_media/{matchId}/{userId}/{fileName} {
      // Read: only the uploader can read directly. Other match participant
      // must use getChatMediaSignedUrl Cloud Function for verified access
      // (CR-AUD-030: match-membership verification).
      allow read: if isOwner(userId);

      // Only the uploader (matching userId) can upload
      allow write: if isOwner(userId)
                   && isValidMediaType()
                   && isUnderSizeLimit();
    }

    // ID verification documents (sensitive - server access only)
    match /verification/{uid}/{document} {
      allow read, write: if false;
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
