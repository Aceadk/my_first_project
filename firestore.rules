rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Check if viewer is blocked by target user
    function isBlockedBy(targetUid) {
      return exists(/databases/$(database)/documents/blocks/$(targetUid + '_' + request.auth.uid));
    }

    // Check if viewer has blocked target user
    function hasBlocked(targetUid) {
      return exists(/databases/$(database)/documents/blocks/$(request.auth.uid + '_' + targetUid));
    }

    // Check if either user has blocked the other
    function hasBlockRelationship(uid) {
      return isBlockedBy(uid) || hasBlocked(uid);
    }

    // Check if current user has Crush Plus subscription
    function isPremium() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'plus';
    }

    // Check if user is female (for stories posting)
    // Handles both nested (mobile: profile.gender) and flat (web: gender) structures
    function isFemale() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return ('profile' in userData && userData.profile.gender == 'female')
          || (!('profile' in userData) && userData.gender == 'female');
    }

    // USERS
    match /users/{uid} {
      // Owner can always read their own profile
      // Other users can read if:
      // 1. They are signed in
      // 2. Neither party has blocked the other
      // 3. Target user's privacy settings allow visibility (or they are matched)
      allow read: if isOwner(uid)
        || (isSignedIn()
            && !hasBlockRelationship(uid)
            && (
              // Profile is visible (not hidden)
              // Handle both nested (mobile) and flat (web) user document structures
              !('profile' in resource.data)
              || !('privacySettings' in resource.data.profile)
              || resource.data.profile.privacySettings.isProfileVisible != false
              // OR viewer is a match (check if match exists between users)
              || exists(/databases/$(database)/documents/matches/$(request.auth.uid < uid ? request.auth.uid + '_' + uid : uid + '_' + request.auth.uid))
            ));

      // Allow owner to create their own document during onboarding
      allow create: if isOwner(uid);

      // Owner can update their own document, but cannot change protected fields.
      // Protected fields (plan, isIdVerified) can only be changed by admin/backend.
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'isIdVerified']);

      // No client deletes; handled via admin.
      allow delete: if false;
    }

    // USERNAME INDEX (server only)
    match /usernames/{username} {
      allow read, write: if false;
    }

    // AUTH SECURITY COLLECTIONS (server only)
    match /auth_email_otps/{otpId} {
      allow read, write: if false;
    }

    match /auth_rate_limits/{key} {
      allow read, write: if false;
    }

    match /auth_audit_logs/{logId} {
      allow read, write: if false;
    }

    // MATCHES
    match /matches/{matchId} {
      // Only participants can read if match is active and no blocks exist.
      allow read: if isSignedIn()
        && resource.data.userIds.hasAny([request.auth.uid])
        && resource.data.status == 'active';

      // Created/updated/deleted only via backend (Cloud Functions/Admin).
      allow create, update, delete: if false;

      // MESSAGES subcollection
      // Messages auto-delete based on user retention settings:
      // - Free users: 1 hour after read (default) or 24 hours (if extended enabled)
      // - Plus users: 7 days after read
      // Each user sees messages based on their own retention, enforced via visibleTo array
      match /messages/{messageId} {
        // Helper to get the match document data
        function getMatchData() {
          return get(/databases/$(database)/documents/matches/$(matchId)).data;
        }

        // Validate participant can access chat:
        // 1. User is a participant
        // 2. Match is active (not unmatched)
        // 3. Neither user has blocked the other
        function canAccessChat() {
          let matchData = getMatchData();
          let otherUid = matchData.userIds[0] == request.auth.uid
            ? matchData.userIds[1]
            : matchData.userIds[0];
          return matchData.userIds.hasAny([request.auth.uid])
            && matchData.status == 'active'
            && !hasBlockRelationship(otherUid);
        }

        // Check if message is still visible to current user
        // Messages have visibleTo array managed by Cloud Functions based on retention
        function isMessageVisible() {
          // If visibleTo doesn't exist (legacy), allow access
          // Otherwise, user must be in the visibleTo array
          return !('visibleTo' in resource.data) || resource.data.visibleTo.hasAny([request.auth.uid]);
        }

        // Only participants can read if:
        // 1. Match is active and no blocks
        // 2. Message is still visible to this user (not expired based on their retention)
        allow read: if isSignedIn() && canAccessChat() && isMessageVisible();

        // Allow create if:
        // 1. Both participants are in the match
        // 2. Match is active
        // 3. Neither user has blocked the other
        // 4. Both users are ID verified
        // 5. Video messages require Crush Plus (premium)
        // 6. Must include visibleTo array with both participants
        allow create: if isSignedIn()
          && canAccessChat()
          && getMatchData().userIds.hasAll(
              [request.auth.uid, request.resource.data.toUserId]
            )
          && get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.isIdVerified == true
          && get(/databases/$(database)/documents/users/$(request.resource.data.toUserId))
            .data.isIdVerified == true
          // Video messages are premium-only (cost savings)
          && (request.resource.data.type != 'video' || isPremium())
          // Must include visibleTo with both participants for retention tracking
          && request.resource.data.visibleTo.hasAll(getMatchData().userIds);

        // Allow receiver to mark message as read.
        // This triggers retention countdown via Cloud Function.
        allow update: if isSignedIn()
          && canAccessChat()
          && resource.data.toUserId == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['isRead', 'readAt'])
          && request.resource.data.isRead == true;

        // No client deletes; handled via Cloud Function based on retention.
        allow delete: if false;
      }
    }

    // MESSAGE REQUESTS (pre-match)
    match /message_requests/{requestId} {
      function otherUserId() {
        return resource.data.fromUserId == request.auth.uid
          ? resource.data.toUserId
          : resource.data.fromUserId;
      }

      // Participants can read their own requests if no blocks exist.
      allow read: if isSignedIn()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid)
        && !hasBlockRelationship(otherUserId());

      // Only sender can create, with block checks.
      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId != request.auth.uid
        && !hasBlockRelationship(request.resource.data.toUserId);

      // Allow participants to delete (migration/expiration cleanup).
      allow delete: if isSignedIn()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);

      allow update: if false;
    }

    // Likes: only creator can write; everyone signed-in can read (adjust as needed).
    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update, delete: if false;
    }

    // Reports: reporter can create; no client updates/deletes.
    match /reports/{reportId} {
      allow read: if false;
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }

    // Blocks: blocker can create; no client updates/deletes.
    match /blocks/{blockId} {
      allow read: if false;
      allow create: if isSignedIn()
        && request.resource.data.blockerId == request.auth.uid;
      allow update, delete: if false;
    }

    // STORIES (Premium + Female users only can post)
    match /stories/{storyId} {
      // Anyone signed in can read stories (with privacy checks handled in queries)
      allow read: if isSignedIn();

      // Only premium users OR female users can create stories
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && (isPremium() || isFemale());

      // Owner can delete their own stories
      allow delete: if isOwner(resource.data.userId);

      // No updates (stories are immutable)
      allow update: if false;
    }

    // CALLS (Premium only)
    match /calls/{callId} {
      // Participants can read their calls
      allow read: if isSignedIn()
        && resource.data.participants.hasAny([request.auth.uid]);

      // Only premium users can initiate calls
      allow create: if isSignedIn()
        && request.resource.data.callerId == request.auth.uid
        && isPremium();

      // Participants can update call status (answer, end)
      allow update: if isSignedIn()
        && resource.data.participants.hasAny([request.auth.uid]);

      allow delete: if false;
    }

    // PRESENCE (Firestore fallback - RTDB is preferred for cost)
    match /presence/{uid} {
      // Owner can always read/write their own presence
      allow read, write: if isOwner(uid);

      // Others can only read if they are premium
      allow read: if isSignedIn() && isPremium();
    }
  }
}
