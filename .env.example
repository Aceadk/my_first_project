# =============================================================================
# CRUSHHOUR APP ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in actual values
# NEVER commit .env with real credentials to version control
# Use --dart-define or flutter_secure_storage for production builds
# =============================================================================

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Options: development, staging, production
FLAVOR=development

# =============================================================================
# AGORA VIDEO/VOICE CALLING
# =============================================================================
# Get these from https://console.agora.io
# Required for video calls and voice notes
AGORA_APP_ID=YOUR_AGORA_APP_ID_HERE
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE_HERE

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Override for custom backend URLs
# Default: Firebase Cloud Functions URL
API_BASE_URL=https://us-central1-crushhour.cloudfunctions.net

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================
# Project IDs for different environments
FIREBASE_PROJECT_ID_DEV=crushhour-dev
FIREBASE_PROJECT_ID_STAGING=crushhour-staging
FIREBASE_PROJECT_ID_PROD=crushhour

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features at build time
ENABLE_CHAT_E2EE=true
ENABLE_VIDEO_CALLS=true
ENABLE_VOICE_NOTES=true
ENABLE_PHOTO_VERIFICATION=true
ENABLE_CONTENT_MODERATION=true
ENABLE_ANALYTICS=true
ENABLE_CRASHLYTICS=true
ENABLE_PERFORMANCE=true

# =============================================================================
# SECURITY
# =============================================================================
# App Check enforcement (set to true after all clients updated)
ENFORCE_APP_CHECK=false

# =============================================================================
# LOCAL DEVELOPMENT (Emulators)
# =============================================================================
# Set to true to use Firebase emulators
USE_EMULATORS=false
EMULATOR_HOST=localhost

# =============================================================================
# BUILD-TIME USAGE
# =============================================================================
# Example production build command:
#
# flutter build appbundle --release \
#   --dart-define=FLAVOR=production \
#   --dart-define=API_BASE_URL=https://us-central1-crushhour.cloudfunctions.net \
#   --dart-define=AGORA_APP_ID=$AGORA_APP_ID \
#   --dart-define=ENABLE_ANALYTICS=true \
#   --dart-define=ENFORCE_APP_CHECK=true
#
# Example iOS build command:
#
# flutter build ios --release \
#   --dart-define=FLAVOR=production \
#   --dart-define=API_BASE_URL=https://us-central1-crushhour.cloudfunctions.net \
#   --dart-define=AGORA_APP_ID=$AGORA_APP_ID
