# =============================================================================
# FIREBASE CLOUD FUNCTIONS ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in actual values
#
# NOTE: functions.config() is deprecated. Use environment variables instead.
# Place your .env file in the functions/ directory.
# See: https://firebase.google.com/docs/functions/config-env
# =============================================================================

# =============================================================================
# OTP AUTHENTICATION
# =============================================================================
# Secret for OTP token generation (generate with: openssl rand -base64 32)
OTP_SECRET=your-secure-random-string-here

# OTP expiration in seconds (default: 300 = 5 minutes)
OTP_EXPIRATION_SECONDS=300

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins for cross-origin requests
CORS_ALLOWED_ORIGINS=https://crushhour.app,https://staging.crushhour.app

# =============================================================================
# EMAIL CONFIGURATION (RESEND)
# =============================================================================
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_API_KEY_HERE
EMAIL_FROM=CrushHour <no-reply@crushhour.app>
SUPPORT_EMAIL=support@crushhour.app

# =============================================================================
# APP CHECK
# =============================================================================
# Set to true to enforce App Check on all callable functions
ENFORCE_APP_CHECK=false

# =============================================================================
# CONTENT MODERATION (External APIs)
# =============================================================================
# Google Cloud Vision API (for image moderation)
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_VISION_API_KEY=your-api-key-here

# AWS Rekognition (alternative image moderation)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

# =============================================================================
# STRIPE PAYMENTS (if using server-side billing)
# =============================================================================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET=sk_live_YOUR_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Stripe price IDs for subscription plans
STRIPE_PRICE_PLUS_MONTHLY=price_xxxxx
STRIPE_PRICE_PLUS_QUARTERLY=price_xxxxx
STRIPE_PRICE_PLUS_ANNUAL=price_xxxxx

# =============================================================================
# AGORA (Token Generation for Video Calls)
# =============================================================================
# Get from https://console.agora.io
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# =============================================================================
# RATE LIMITING
# =============================================================================
# Override default rate limits (optional)
# OTP_REQUEST_LIMIT=5
# OTP_REQUEST_WINDOW_MINUTES=10
# LOGIN_ATTEMPT_LIMIT=8
# LOGIN_ATTEMPT_WINDOW_MINUTES=10

# =============================================================================
# DEPLOYMENT
# =============================================================================
# Build functions:
#   cd functions && npm run build
#
# Deploy to production:
#   firebase deploy --only functions --project crushhour
#
# Deploy to staging:
#   firebase deploy --only functions --project crushhour-staging
#
# NOTE: Environment variables are loaded from .env file automatically.
# Do not use functions:config:set (deprecated).
