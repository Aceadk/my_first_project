{
  "name": "functions",
  "scripts": {
    "build": "tsc",
    "lint": "eslint --ext .ts src",
    "test": "npm run build && mocha --recursive --exit --ignore test/securityAbuseLanes.test.js",
    "test:security": "npm run build && mocha --exit test/securityAbuseLanes.test.js",
    "serve": "npm run build && firebase emulators:start --only functions",
